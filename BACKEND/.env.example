# ============================================
#   COPY THIS FILE TO .env AND FILL VALUES
# ============================================

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/parking_system?retryWrites=true&w=majority

# Server port (Render uses PORT automatically)
PORT=5000

# Plate Recognizer API Key
# Get free key from: https://platerecognizer.com → Sign Up (2500 free scans/month)
PLATE_RECOGNIZER_API_KEY=your_plate_recognizer_api_key_here

# Fine amount in Rupees (change if needed)
FINE_AMOUNT=500

# Your building/company name (appears in receipts)
COMPANY_NAME=My Building Society

# Secret token for admin routes (make this a long random string)
ADMIN_SECRET=change_this_to_something_secret_123
